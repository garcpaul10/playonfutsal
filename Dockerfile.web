FROM node:22-slim AS builder
RUN npm install -g pnpm
WORKDIR /app
COPY . .
RUN pnpm install --ignore-scripts
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
RUN pnpm --filter @workspace/playon run build

FROM node:22-slim
RUN npm install -g serve
WORKDIR /app
COPY --from=builder /app/artifacts/playon/dist/public ./dist
EXPOSE 3000
CMD ["serve", "dist", "-p", "3000"]
